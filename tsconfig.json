{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "components/Card.jsx",
    "app/(tabs)/Settings.jsx",
    "app/(tabs)/AddTask.jsx",
    "app/(tabs)/Calendar.jsx"
  ]
}
